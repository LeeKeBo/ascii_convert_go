/* 全局样式 */
page {
  background-color: #111111;
  color: #e0e0e0;
  font-family: -apple-system, sans-serif;
}

.btn-primary {
  background: #6ee7b7;
  color: #111;
  border: none;
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.btn-secondary {
  background: none;
  border: 1px solid #a78bfa;
  color: #a78bfa;
  border-radius: 12rpx;
  padding: 18rpx 36rpx;
  font-size: 28rpx;
}

.btn-disabled {
  opacity: 0.4;
}
