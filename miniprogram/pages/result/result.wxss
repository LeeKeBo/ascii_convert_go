.container {
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.result-wrap {
  background: #111;
  border-radius: 12rpx;
  overflow: hidden;
  width: 100%;
}

.result-img {
  width: 100%;
  display: block;
}

.compare-wrap {
  background: #1c1c1c;
  border-radius: 12rpx;
  padding: 16rpx;
}

.compare-label {
  font-size: 22rpx;
  color: #555;
  margin-bottom: 8rpx;
  display: block;
}

.origin-img {
  width: 100%;
  height: 200rpx;
}

.action-row {
  display: flex;
  gap: 20rpx;
}

.action-row .btn-primary,
.action-row .btn-secondary {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.status-text {
  font-size: 24rpx;
  color: #6ee7b7;
  text-align: center;
}
